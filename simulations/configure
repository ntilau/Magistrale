#!/usr/bin/env bash
# ============================================================================
# configure — Install Wine for running FEM solvers via Wine
# ============================================================================
set -euo pipefail

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

install_macos() {
  echo "Detected macOS"
  if ! has_cmd brew; then
    echo "Homebrew not found. Install it first: https://brew.sh"
    exit 1
  fi
  if has_cmd wine; then
    echo "Wine already installed."
  else
    echo "Installing Wine..."
    brew install --cask wine-stable
  fi
  echo "Done. You may also need to install: brew install make"
}

install_debian_like() {
  echo "Detected Debian/Ubuntu"
  if has_cmd wine; then
    echo "Wine already installed."
  else
    echo "Installing Wine..."
    sudo dpkg --add-architecture i386
    sudo apt-get update
    sudo apt-get install -y wine wine32 wine64 make
  fi
  echo "Done."
}

install_arch() {
  echo "Detected Arch Linux"
  if has_cmd wine; then
    echo "Wine already installed."
  else
    echo "Installing Wine..."
    sudo pacman -Sy --needed --noconfirm wine make
  fi
  echo "Done."
}

install_fedora_like() {
  echo "Detected Fedora/RHEL-like Linux"
  if has_cmd wine; then
    echo "Wine already installed."
  else
    echo "Installing Wine..."
    sudo dnf install -y wine make
  fi
  echo "Done."
}

main() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      install_macos
      ;;
    Linux)
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}" in
          ubuntu|debian)
            install_debian_like
            ;;
          arch)
            install_arch
            ;;
          fedora|rhel|centos)
            install_fedora_like
            ;;
          *)
            echo "Linux distribution '${ID:-unknown}' is not handled automatically."
            echo "Install manually: wine and make."
            exit 1
            ;;
        esac
      else
        echo "/etc/os-release not found. Install manually: wine and make."
        exit 1
      fi
      ;;
    *)
      echo "Unsupported OS: $os"
      echo "Install manually: wine and make."
      exit 1
      ;;
  esac

  echo ""
  echo "Configuration complete."
  echo "Run 'make help' in the simulations/ directory for available targets."
}

main "$@"
